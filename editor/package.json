{
  "name": "resume-editor",
  "version": "1.0.0",
  "description": "Internship Portal — bilingual internship tracker and résumé editor with LaTeX compilation",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node server/index.js",
    "dev": "concurrently --kill-others \"npm run dev:client\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "validate:catalog": "node server/validate-catalog.js",
    "validate:catalog:links": "node server/validate-catalog.js --links",
    "refresh:catalog": "node server/refresh-catalog.js",
    "audit:catalog:llm": "node server/audit-catalog-llm.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src server"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase": "^12.15.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.395.0",
    "openai": "^6.45.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.44.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
