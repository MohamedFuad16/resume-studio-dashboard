<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Firebase Auth stores the signed-in session in the keychain. Keychain access
  requires the app to be signed with an application-identifier, and the access
  group must carry the team prefix — codesign expands $(AppIdentifierPrefix) to
  "<TEAMID>." from the signing settings (team 74G5KQR6DG), on device and
  simulator alike now that signing is automatic with the personal team.

  application-identifier itself is NOT declared here: with profile-based signing
  Xcode injects it, and a hardcoded value (the old un-prefixed one) mismatches
  the profile and fails the device install.
-->
<plist version="1.0">
<dict>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.mohamedfuad.internshipportal</string>
	</array>
</dict>
</plist>
